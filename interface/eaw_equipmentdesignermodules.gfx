spriteTypes = {

###################################################
# Contains GFX for the ship modules shown on top of the blue print
#
# Names of the modules are normalized and *must* obey the following naming
# convention.
#
# "GFX_SM_ ( SHIP_CLASS ) "_" ( MODULE_KEY ) "_" ( MODIFIER )
#( MODIFIER ) is optional
# Where:
# * SHIP_CLASS looks like "ship_hull_carrier"
# * MODULE_KEY looks like "ship_light_battery"
# * COUNTRY MODIFIER looks like "ger" (for Germany for example).
# Example:
# Each sprite corresponds to one ship hull type and one module only. 
# * "GFX_SM_ship_hull_carrier_ship_light_battery_ger"

###################################################

