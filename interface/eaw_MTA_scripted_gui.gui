

guiTypes = {
	
	containerWindowType = {
		name = "MTA_artifacts_tab_gui_container"
		position = { x = 1100 y = 4 }
		buttonType = {
			name = "button_open"
			spriteType = "GFX_decision_sombra_book"
			position = { x = -3 y = -2 }
			pdx_tooltip = "MTA_artifact_tab_tt"
			pdx_tooltip_delayed = "MTA_artifact_tab_tt_desc"
			shortcut = "ctrl+o"
			clicksound = "click_ok"
		}
		iconType = {
			name = "button_alert"
			spriteType = "GFX_button_arrows_alert"
			#position = { x = -5 y = 35 }
			position = { x = -3 y = 35 }
		}
	}
	
	containerWindowType = {
		name = "MTA_artifact_list_window"
		size = { width = 585 height = 426 }

		hide_position = { x = -443 y = -1000 }
		show_position = { x = -443 y = -210 }
		show_animation_type = decelerated
		hide_animation_type = accelerated
		animation_time = 500

		moveable = yes
		clipping = no
		show_sound = menu_open_window
		click_to_front = yes

		orientation = center

		background = {
			name = "Background"
			quadTextureSprite = "GFX_MTA_artifacts_bg"
		}

		### Header ###
		iconType = {
			name = "Cave_Icon"
			position = { x = 22 y = 11 }
			spriteType = "GFX_decision_sombra_book"
		}

		instantTextboxType = {
			name = "title"
			position = { x = 75 y = 11 }
			font = "hoi_36header"
			text = MTA_artifact_cave_title
			maxWidth = 500
			maxHeight = 36
			format = left
		}
		
		instantTextboxType = {
			name = "arty_number"
			position = { x = 75 y = 16 }
			font = "hoi_30header"
			text = MTA_artifact_cave_artifacts_count
			maxWidth = 450
			maxHeight = 30
			format = right
		}

		buttonType = {
			name = "button_close"
			position = {x = -44 y = 12 }
			spriteType = "GFX_NV_btn_close"
			clicksound = click_close
			pdx_tooltip = "CLOSE"
			shortcut = "ESCAPE"
			orientation = UPPER_RIGHT
		}
		### End Header ###

		iconType = {
			name = "safe"
			spriteType = "GFX_MTA_safe"
			position = { x = -134 y = 54 }
			alwaystransparent = yes
		}
		iconType = {
			name = "selected_icon"
			spriteType = "GFX_idea_unknown"
			position = { x = 173 y = 235 }
			centerposition = yes
			scale = 1.75
		}
		instantTextBoxType = {
			name = "selected_artifact_text"
			position = { x = 43 y = 60 }
			text = [GetMTAArtifactNameSelected]
			font = "hoi_24header"
			maxwidth = 264
			maxheight = 35
			format = center
			fixedsize = yes
			vertical_alignment = center
		}

		containerWindowType = {
			name = "MTA_artifact_list_container"
			position = { x = 340 y = 50 }
			size = { width = 240 height = 371 } 
			margin = { top = 10 bottom = 10 }
			Orientation = upper_left

			verticalScrollbar = "right_vertical_slider"

			background = {
				name = "Background"
				quadTextureSprite = "GFX_MTA_artifacts_list_bg"
			}

			gridboxtype = {
				name = "MTA_artifacts_list_grid"
				position = { x = 10 y = 0 }
				size = { width = 68 height = 100%% }
				slotsize = { width = 68 height = 68 }
				max_slots_horizontal = 3
				add_horizontal = yes
			}
		}
	}
	
	containerWindowType = {
		name = "MTA_artifact_entry"
