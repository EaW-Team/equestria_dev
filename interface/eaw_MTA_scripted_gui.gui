

guiTypes = {
	
	containerWindowType = {
		name = "MTA_artifacts_tab_gui_container"
		position = { x = 1100 y = 4 }
		buttonType = {
			name = "button_open"
			spriteType = "GFX_decision_sombra_book"
			position = { x = -3 y = -2 }
			pdx_tooltip = "MTA_artifact_tab_tt"
			pdx_tooltip_delayed = "MTA_artifact_tab_tt_desc"
